{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/orders", "destination": "/api/orders" },
    { "source": "/api/orders/(.*)", "destination": "/api/orders?path=$1" },
    { "source": "/api/products", "destination": "/api/products" },
    { "source": "/api/products/(.*)", "destination": "/api/products?path=$1" },
    { "source": "/api/categories", "destination": "/api/categories" },
    { "source": "/api/checkout", "destination": "/api/checkout" },
    { "source": "/api/seller/orders", "destination": "/api/seller/orders" },
    { "source": "/api/storefront/payment-settings", "destination": "/api/storefront/payment-settings" },
    { "source": "/api/storefront/stock-intakes", "destination": "/api/storefront/stock-intakes" },
    { "source": "/api/stripe/connect", "destination": "/api/stripe/connect" },
    { "source": "/api/uploads/blob", "destination": "/api/uploads/blob" },
    { "source": "/api/(.*)", "destination": "/api?path=$1" },
    { "source": "/docs/user-guides", "destination": "/docs/user-guides/index.html" },
    { "source": "/docs/user-guides/marketplace-rules", "destination": "/docs/user-guides/marketplace-rules.html" },
    { "source": "/docs/user-guides/seller-guide", "destination": "/docs/user-guides/seller-guide.html" },
    { "source": "/docs", "destination": "/docs/index.html" },
    { "source": "/docs/developers", "destination": "/docs/developers/index.html" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "headers": [
      {
        "source": "/(.*)",
        "headers": [
          { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
        ]
      }
    ]
  }
  
